@{
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
    ViewBag.Title = "Login | FathFinance";
}

<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4">
    <div class="max-w-md w-full bg-white rounded-xl shadow-lg p-8 space-y-6">

        <h2 class="text-2xl font-extrabold text-gray-900 text-center">
            Login to Your Account
        </h2>

        @if (TempData["Success"] != null)
        {
            <div class="text-green-600 text-center mb-4">
                @TempData["Success"]
            </div>
        }

        @Html.ValidationSummary(false, "", new { @class = "text-red-500 mb-4" })

        @using (Html.BeginForm("login", "Auth", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <input type="email" name="email" required
                           class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 outline-none" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                    <input type="password" name="password" required
                           class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 outline-none" />
                </div>

                <button type="submit" class="w-full py-2 px-4 bg-blue-600 text-white font-semibold rounded-md hover:bg-blue-700">
                    Login
                </button>
            </div>
        }

        <div class="text-center text-sm text-gray-500 mt-4">
            Don't have an account?
            <a href="@Url.Action("Register", "Auth")" class="text-blue-600 hover:underline">
                Register
            </a>
        </div>
    </div>
</div>