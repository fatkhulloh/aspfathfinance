@model ImsMVC.Models.RegisterViewModel

@{
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
    ViewBag.Title = "Register | FathFinance";
}

<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4">
    <div class="max-w-md w-full bg-white rounded-xl shadow-lg p-8 space-y-6">

        <h2 class="text-2xl font-extrabold text-gray-900 text-center">
            Register Account
        </h2>

        @Html.ValidationSummary(false, "", new { @class = "text-red-500" })

        @using (Html.BeginForm("register", "Auth", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="space-y-4">
                <div>
                    @Html.LabelFor(m => m.Username)
                    @Html.TextBoxFor(m => m.Username, new { @class = "w-full px-4 py-2 border border-gray-300 rounded-md" })
                </div>

                <div>
                    @Html.LabelFor(m => m.Email)
                    @Html.TextBoxFor(m => m.Email, new { type = "email", @class = "w-full px-4 py-2 border border-gray-300 rounded-md" })
                </div>

                <div>
                    @Html.LabelFor(m => m.Password)
                    @Html.PasswordFor(m => m.Password, new { @class = "w-full px-4 py-2 border border-gray-300 rounded-md" })
                </div>

                <div>
                    @Html.LabelFor(m => m.ConfirmPassword)
                    @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "w-full px-4 py-2 border border-gray-300 rounded-md" })
                </div>

                <button type="submit" class="w-full py-2 px-4 bg-blue-600 text-white font-semibold rounded-md hover:bg-blue-700">
                    Register
                </button>
            </div>
        }

        <div class="text-center text-sm text-gray-500">
            Already have an account? <a href="@Url.Action("Login", "Auth")" class="text-blue-600 hover:underline">Login</a>
        </div>
    </div>
</div>