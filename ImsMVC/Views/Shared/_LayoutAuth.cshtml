@using System.Web
@using System.Web.Mvc
@{
    var userId = Session["UserId"];
    var username = Session["Username"] ?? "";
    Layout = null;
    string pageTitle = ViewBag.Title ?? "Finventori";
    string metaDescription = ViewBag.MetaDescription ?? "";
}

<!DOCTYPE html>
<html lang="id">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - FathFinance</title>
    <meta name="description" content="@metaDescription" />

    <script src="https://cdn.tailwindcss.com"></script>
    @RenderSection("HeadContent", required: false)
</head>
<body class="bg-gray-50 font-sans">

    <header class="bg-gradient-to-r from-indigo-600 via-blue-600 to-purple-600 text-white shadow-lg sticky top-0 z-50">
    </header>

    <main class="container mx-auto mt-12 px-4 md:px-6">
        @RenderBody()
    </main>


</body>
</html>